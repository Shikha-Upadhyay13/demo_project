GROQ_API_KEY=gsk_...
YOUTUBE_API_KEY=AIza...
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=adaptivai-mini

# Storage backend — 'sqlite' (default, local files) or 'postgres' (Supabase/Neon/etc).
# When 'postgres', DATABASE_URL is required.
STORAGE_BACKEND=sqlite

# Required when STORAGE_BACKEND=postgres. Supabase format:
#   postgresql://postgres.<project_ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Or direct: postgresql://postgres:<password>@db.<project_ref>.supabase.co:5432/postgres
# DATABASE_URL=

# Optional model overrides (defaults shown).
# GENERATION_MODEL=llama-3.3-70b-versatile
# ANSWER_MODEL=llama-3.3-70b-versatile
# ROUTER_MODEL=llama-3.1-8b-instant
# SMALL_MODEL=llama-3.1-8b-instant
# HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
